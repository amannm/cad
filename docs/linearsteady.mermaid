flowchart LR
    U([Config])
    CFG["Config parser + schema validation\nunits, dimensions, required sections"]
    SPEC["ProblemSpec IR\ncanonical, hashable, versioned"]
    UNITS["Units + coordinate frame\ncanonical scale"]
    TAGS["Semantic tag registry\nname, dim, id, role, coverage rules"]
    CACHE["Artifact cache + provenance\nspec, CAD, mesh, form, operator hashes"]
    DAG["Execution DAG / artifact planner\nrecompute decisions, stage runners, invalidation"]
    CONTRACT["Geometry/mesh contract\ndimension, entity names, scale, tag coverage, cell type/order"]
    COUPLING["Multiphysics coupling manager\nmonolithic/staggered policy, block dependencies, transfer/projection"]
    RESTART["Restart schema/version manager\nmesh hash, space signature, fields, provenance"]

    CQ["CadQuery geometry builder\nparameterized solids/surfaces"]
    GEOCHK["Geometry validator\norientation, watertightness, scale, named entities"]
    GM["Gmsh mesher\nphysical groups + mesh size fields"]
    TAGMAP["Tag reconciliation\nsemantic tags ↔ gmsh physical groups"]
    MESHVAL["Mesh/topology validator\ncell/facet coverage, quality, MPI partition sanity"]
    IM["Mesh adapter\nGmsh → DOLFINx MeshData\nmesh + cell/facet/edge/vertex tags"]

    FS["Field/space registry\nscalar, vector, mixed blocks; measures"]
    DOFPLAN["DOF/block layout plan\nfield ordering, index sets, nullspace hints"]
    MDB["Material DB\nsemantic region → normalized params"]
    CF["Coefficient/constant builder\ncell-wise/facet-wise immutable data"]
    LOADS["Load/source builder\nsemantic facets/cells"]
    BCS["Constraint/BC registry\nstrong Dirichlet + weak/natural terms"]

    PHYS["UFL form factory\nlinear steady residual templates"]
    FORMCHK["Form validation\narity, units, block shape, BC consistency"]
    FORMCOMPILE["Compiled-form cache\nUFL/FFCx/dolfinx forms"]
    ASMPLAN["Assembly + preconditioner plan\noperator signature, MatNest/block layout"]
    ASSY["Assemble operators/vectors\nzero/reuse matrices; lift/apply BCs"]
    LINSYS["Linear system package\nA, b, P, nullspace, near-nullspace"]
    KSP["PETSc KSP/PC solve\noptions prefix + monitors"]

    QC["Solution verification\nresidual, conservation, reactions, invariants"]
    OBS["Diagnostics/observability bus\nlogs, timings, PETSc reasons, provenance"]
    POST["Postprocess\nderived fields, probes, integrals"]
    IO["Output manager\ncheckpoint vs visualization formats"]
    OUT["Outputs\nsolution, mesh, metadata, diagnostics"]

    U --> CFG --> SPEC
    SPEC --> UNITS
    SPEC --> TAGS
    SPEC --> DAG --> CACHE
    SPEC -- geometry params --> CQ
    SPEC -- mesh params --> GM
    SPEC -- field/material/load/BC/physics/solver specs --> PHYS
    DAG -- geometry stage --> CQ
    DAG -- mesh stage --> GM
    DAG -- forms/solve stages --> PHYS
    DAG -- output stage --> IO
    CACHE -- reusable artifacts + provenance --> DAG

    UNITS -- scale/frame rules --> CQ
    CQ -- CAD model --> GEOCHK
    GEOCHK -- validated CAD --> CACHE
    GEOCHK -- geometry metadata --> CONTRACT
    GEOCHK -- validated CAD --> GM
    TAGS -- required groups --> TAGMAP
    TAGS -- required semantic coverage --> CONTRACT
    GM -- gmsh model + mesh + physical names --> TAGMAP
    TAGMAP -- semantic mesh groups --> MESHVAL
    TAGMAP -- physical group ids/names --> CONTRACT
    UNITS -- coordinate scale --> MESHVAL
    CONTRACT -- mesh requirements --> MESHVAL
    MESHVAL -- validated mesh + tags --> IM
    CONTRACT -- import contract --> IM
    IM -- MeshData artifacts --> CACHE

    IM -- mesh + meshtags + physical_groups --> FS
    TAGS -- measure/tag names --> FS
    FS --> DOFPLAN
    SPEC -- coupling policy --> COUPLING
    FS -- field blocks --> COUPLING
    DOFPLAN -- block dependencies/layout --> COUPLING
    DOFPLAN -- block layout + nullspaces --> LINSYS
    SPEC -- material map --> MDB
    UNITS -- unit checks --> MDB
    TAGS -- cell tag validation --> MDB
    MDB -- normalized material specs --> CF
    IM -- mesh + cell/facet tags --> CF
    SPEC -- load specs --> LOADS
    SPEC -- BC specs --> BCS
    TAGS -- semantic lookup --> LOADS
    TAGS -- semantic lookup --> BCS
    IM -- mesh + tags --> LOADS
    IM -- mesh + tags --> BCS
    FS -- spaces + measures --> LOADS
    FS -- spaces + measures --> BCS

    FS -- trial/test/block spaces + dx/ds --> PHYS
    CF -- coefficients/constants --> PHYS
    COUPLING -- coupled field plan --> PHYS
    LOADS -- body/natural terms --> PHYS
    BCS -- weak terms --> PHYS
    PHYS -- residual/bilinear/linear forms --> FORMCHK
    FORMCHK -- valid forms --> FORMCOMPILE
    FORMCOMPILE -- compiled forms + signature --> ASMPLAN
    DOFPLAN -- layout + index sets --> ASMPLAN
    ASMPLAN -- recipe + reuse policy --> ASSY
    BCS -- strong constraints --> ASSY
    ASSY -- A, b, P --> LINSYS
    LINSYS -- configured system --> KSP
    SPEC -- PETSc options --> KSP

    KSP -- solution + solve_info --> QC
    LINSYS -- A, b, P --> QC
    QC -- accepted solution + diagnostics --> POST
    KSP -- monitors/reasons --> OBS
    QC -- checks --> OBS
    CACHE -- provenance hashes --> OBS
    FS -- spaces + measures --> POST
    POST -- derived fields + integrals --> IO
    IM -- mesh hash + tag signature --> RESTART
    FS -- space signature --> RESTART
    POST -- field/output signatures --> RESTART
    CACHE -- provenance bundle --> RESTART
    RESTART -- compatible restart/checkpoint package --> IO
    IO -- checkpoints + visualization files --> OUT
    OBS -- diagnostics --> OUT
    IM -- mesh + tags --> OUT
