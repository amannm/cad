flowchart TD
    RUNPLAN["RunPlan\nmode, time policy, output cadence,\ncheckpoint cadence, restart"]
    STEPPER["Stepper\nsteady / fixed transient / adaptive transient /\nload ramp / continuation"]
    PHYS["PhysicsPackage\nforms, material updates, invariants"]
    DISCRETE["DiscreteModel\nspaces, dofs, measures, BC/load bindings"]
    STATE["StateStore\ncurrent, trial, history, commit/rollback"]
    ASSEMBLY["AssemblyPlan / AlgebraicSystem\nassemble F,J,P,A,b,M\napply BCs, nullspaces, block layout"]
    PROFILE["SolverProfile\nPETSc prefix tree, KSP/SNES/PC options,\nfieldsplit policy, fallbacks"]
    DRIVER["SolverDriver\nsolve one algebraic system"]
    DIAG["Diagnostics\nresiduals, iterations, monitors,\nfailed steps, timings"]
    ACCEPT{"Accept step?"}
    COMMIT["commit state\nwrite outputs/checkpoint if due"]
    ROLLBACK["rollback state\nadapt dt / fallback / abort"]
    CKPT["CheckpointPayload + RestartContract"]
    REPORT["RunReport"]
    OUT["Solution outputs"]
    POST["Postprocess"]
    VIZ["VisualizationBundle"]

    RUNPLAN --> STEPPER
    STEPPER --> STATE
    STEPPER --> ASSEMBLY
    PHYS --> ASSEMBLY
    DISCRETE --> ASSEMBLY
    STATE --> ASSEMBLY
    PROFILE --> DRIVER
    ASSEMBLY --> DRIVER
    DRIVER --> DIAG
    DRIVER --> ACCEPT

    ACCEPT -->|yes| COMMIT
    ACCEPT -->|no| ROLLBACK

    COMMIT --> STATE
    COMMIT --> OUT
    COMMIT --> CKPT
    ROLLBACK --> STEPPER

    OUT --> POST --> VIZ
    DIAG --> REPORT
    CKPT --> REPORT
    VIZ --> REPORT
