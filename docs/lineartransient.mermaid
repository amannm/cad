flowchart LR
    U([Config])
    CFG["Config parser + schema validation\nunits, dimensions, time, required sections"]
    SPEC["ProblemSpec IR\ncanonical, hashable, versioned"]
    UNITS["Units + coordinate frame\ncanonical scale"]
    TAGS["Semantic tag registry\nname, dim, id, role, coverage rules"]
    TIME["Time policy\nscheme, dt limits, output cadence, adaptivity"]
    CACHE["Artifact cache + provenance\nspec, CAD, mesh, form, operator hashes"]
    DAG["Execution DAG / artifact planner\nrecompute decisions, stage runners, invalidation"]
    CONTRACT["Geometry/mesh contract\ndimension, entity names, scale, tag coverage, cell type/order"]
    COUPLING["Multiphysics coupling manager\nmonolithic/staggered policy, block dependencies, transfer/projection"]
    RESTART["Restart schema/version manager\nmesh hash, space signature, fields, history, internal vars"]

    CQ["CadQuery geometry builder"]
    GEOCHK["Geometry validator\norientation, watertightness, scale, named entities"]
    GM["Gmsh mesher\nphysical groups + mesh size fields"]
    TAGMAP["Tag reconciliation\nsemantic tags ↔ gmsh physical groups"]
    MESHVAL["Mesh/topology validator\ncoverage, quality, MPI partition sanity"]
    IM["Mesh adapter\nGmsh → DOLFINx MeshData"]

    FS["Field/space registry\nscalar, vector, mixed blocks; measures"]
    DOFPLAN["DOF/block layout plan\nfield ordering, index sets, nullspace hints"]
    MDB["Material DB\nsemantic region → normalized params"]
    CF["Coefficient manager\nstatic + time-dependent fields"]
    LOADS["Load/source manager\ntime-aware functions"]
    BCS["Constraint/BC manager\ntime-aware strong + weak terms"]
    IC["Initial/restart builder\nproject/interpolate/import restart"]
    STATE["State/history store\nu_n, u_{n-1}, checkpoints, output state"]

    PHYS["UFL transient form factory\nmass/stiffness/source templates"]
    STEPCTX["Step context\nscheme, t, dt, history, coefficients"]
    FORMCHK["Form validation\narity, units, block shape, BC consistency"]
    FORMCOMPILE["Compiled-form cache\nUFL/FFCx/dolfinx forms"]
    OPCACHE["Operator/preconditioner cache\nM/K/A/P signatures; reuse policy"]
    ASSY["Assemble step system\nzero/reuse matrices; lift/apply BCs"]
    LINSYS["Step linear system\nA_step, b_step, P_step"]
    KSP["PETSc KSP/PC solve\noptions prefix + monitors"]
    ERR["Step acceptance checks\nresidual, invariants, estimator"]
    ADV["Advance controller\naccept/reject, rollback, adapt dt"]

    OBS["Diagnostics/observability bus\nlogs, timings, PETSc reasons, provenance"]
    POST["Postprocess\nderived fields, probes, integrals"]
    IO["Output manager\nrestart checkpoints vs visualization cadence"]
    OUT["Outputs\ncheckpoints, time series, metadata, diagnostics"]

    U --> CFG --> SPEC
    SPEC --> UNITS
    SPEC --> TAGS
    SPEC -- time spec + adaptivity policy --> TIME
    SPEC --> DAG --> CACHE
    SPEC -- geometry params --> CQ
    SPEC -- mesh params --> GM
    SPEC -- field/material/load/BC/physics/solver specs --> PHYS
    DAG -- geometry stage --> CQ
    DAG -- mesh stage --> GM
    DAG -- forms/solve stages --> PHYS
    DAG -- output stage --> IO
    CACHE -- reusable artifacts + provenance --> DAG

    UNITS --> CQ
    CQ --> GEOCHK
    GEOCHK --> CACHE
    GEOCHK -- geometry metadata --> CONTRACT
    GEOCHK --> GM
    TAGS --> TAGMAP
    TAGS -- required semantic coverage --> CONTRACT
    GM --> TAGMAP
    TAGMAP --> MESHVAL
    TAGMAP -- physical group ids/names --> CONTRACT
    UNITS --> MESHVAL
    CONTRACT -- mesh requirements --> MESHVAL
    MESHVAL --> IM
    CONTRACT -- import contract --> IM
    IM --> CACHE

    IM --> FS
    TAGS --> FS
    FS --> DOFPLAN
    SPEC -- coupling policy --> COUPLING
    FS -- field blocks --> COUPLING
    DOFPLAN -- block dependencies/layout --> COUPLING
    SPEC -- material map --> MDB
    UNITS --> MDB
    TAGS --> MDB
    MDB --> CF
    IM --> CF
    FS --> IC
    SPEC -- ic/restart spec --> IC
    IC --> STATE
    SPEC --> LOADS
    SPEC --> BCS
    TIME -- t, dt --> CF
    TIME -- t, dt --> LOADS
    TIME -- t, dt --> BCS
    TAGS --> LOADS
    TAGS --> BCS
    IM --> LOADS
    IM --> BCS
    FS --> LOADS
    FS --> BCS

    TIME -- t, dt, step_id --> STEPCTX
    STATE -- history/restart data --> STEPCTX
    FS -- spaces + measures --> PHYS
    CF -- coefficients(t) --> STEPCTX
    COUPLING -- coupled field plan --> STEPCTX
    LOADS -- terms(t) --> STEPCTX
    BCS -- weak terms(t) --> STEPCTX
    PHYS -- semi-discrete templates --> STEPCTX
    STEPCTX -- step forms --> FORMCHK
    FORMCHK --> FORMCOMPILE
    FORMCOMPILE -- compiled forms + signatures --> OPCACHE
    DOFPLAN --> OPCACHE
    OPCACHE -- cached operator/PC if unchanged --> LINSYS
    OPCACHE -- assembly required --> ASSY
    BCS -- strong constraints(t) --> ASSY
    ASSY --> LINSYS
    LINSYS --> KSP
    SPEC -- PETSc options --> KSP
    KSP -- u_{n+1}, solve_info --> ERR
    ERR -- accepted/rejected + suggested_dt --> ADV
    ADV -- committed state --> STATE
    ADV -- rollback rejected state --> STATE
    ADV -- dt feedback --> TIME

    STATE -- output-time states --> POST
    FS --> POST
    POST --> IO
    STATE -- restart checkpoints --> IO
    IM -- mesh hash + tag signature --> RESTART
    FS -- space signature --> RESTART
    STATE -- field/time history signatures --> RESTART
    CACHE -- provenance bundle --> RESTART
    RESTART -- compatible restart/checkpoint package --> IO
    KSP --> OBS
    ERR --> OBS
    ADV --> OBS
    CACHE --> OBS
    IO --> OUT
    OBS --> OUT
    IM --> OUT
