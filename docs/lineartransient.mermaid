flowchart LR
    U([Config])
    CFG["Config parser + schema validation\nunits, dimensions, time, required sections"]
    UNITS["Units + coordinate frame\ncanonical scale"]
    TAGS["Semantic tag registry\nname, dim, id, role"]
    TIME["Time integrator backend\ncustom loop or PETSc TS/TSAdapt"]
    CACHE["Artifact cache + provenance\nCAD, mesh, form, operator hashes"]
    CQ["CadQuery\nbuild CAD"]
    GM["Gmsh\nphysical names + mesh fields"]
    VAL["Validate geometry, tags, mesh quality"]
    IM["Mesh adapter\nGmsh → DOLFINx MeshData"]
    FS["Field/space registry\nscalar, vector, mixed blocks; measures"]
    MDB["Material DB\ntag/name → normalized params"]
    CF["Coefficient/constant builder\nstatic + time-dependent fields"]
    LOADS["Load/source builder\ntime-aware functions"]
    BCS["BC builder\ntime-aware Dirichlet + weak terms"]
    IC["Initial condition builder\nproject/interpolate/import restart"]
    STATE["State/history manager\nu_n, u_{n-1}, restart, output state"]
    PHYS["UFL transient form factory\nsemi-discrete templates"]
    STEP["Step form instantiation\nscheme, t, dt, history"]
    OPcache["Operator/preconditioner cache\nreuse matrix/PC when unchanged"]
    ASSY["Assemble + lift/apply BCs"]
    KSP["PETSc KSP/PC solve\noptions prefix + monitors"]
    ERR["Step quality checks\nresidual, invariants, error estimate"]
    ADV["Advance state\naccept/reject, adapt dt"]
    POST["Postprocess\nderived fields, probes, integrals"]
    IO["Output manager\ncheckpoint cadence vs visualization cadence"]
    OUT["Outputs\ncheckpoints, time series, diagnostics"]

%% Config and front-end
    U --> CFG
    CFG --> UNITS
    CFG --> TAGS
    CFG -- time spec + adaptivity policy --> TIME
    CFG -- normalized hashable config --> CACHE
    CFG -- geometry params --> CQ
    CFG -- mesh params --> GM
    CFG -- field/space spec --> FS
    CFG -- material/load/BC/physics/solver specs --> PHYS

%% Geometry + mesh
    UNITS -- scale/frame rules --> CQ
    CQ -- CAD model --> CACHE
    CQ -- CAD model --> GM
    TAGS -- required physical groups --> GM
    GM -- gmsh mesh + physical names --> VAL
    TAGS -- semantic schema --> VAL
    UNITS -- coordinate scale --> VAL
    VAL -- validated mesh + groups --> IM
    IM -- mesh, cell/facet tags, physical_groups --> FS
    IM -- mesh artifacts --> CACHE

%% Coefficients, loads, BCs, ICs
    TAGS -- measure/tag names --> FS
    UNITS -- unit checks --> MDB
    TAGS -- cell tag validation --> MDB
    MDB -- normalized material specs --> CF
    IM -- mesh + tags --> CF
    FS -- spaces --> IC
    CFG -- ic/restart spec --> IC
    IC -- initial state --> STATE
    CFG -- load specs --> LOADS
    CFG -- BC specs --> BCS
    TIME -- t, dt --> CF
    TIME -- t, dt --> LOADS
    TIME -- t, dt --> BCS
    TAGS -- semantic lookup --> LOADS
    TAGS -- semantic lookup --> BCS
    IM -- mesh + tags --> LOADS
    IM -- mesh + tags --> BCS
    FS -- spaces + measures --> LOADS
    FS -- spaces + measures --> BCS

%% Time loop
    TIME -- t, dt, step_id --> STATE
    STATE -- history/restart data --> STEP
    FS -- trial/test/block spaces + measures --> PHYS
    CF -- coefficients/constants --> PHYS
    LOADS -- body/natural terms(t) --> STEP
    BCS -- weak terms(t) --> STEP
    PHYS -- semi-discrete form templates --> STEP
    STEP -- a_step, L_step, operator signature --> OPcache
    OPcache -- cached A/PC if signature unchanged --> KSP
    OPcache -- assembly required --> ASSY
    BCS -- Dirichlet BCs(t) --> ASSY
    ASSY -- A_bc, b_bc --> KSP
    CFG -- PETSc options --> KSP
    KSP -- u_{n+1}, solve_info --> ERR
    ERR -- accepted/rejected + suggested_dt --> ADV
    ADV -- committed state --> STATE
    ADV -- dt feedback --> TIME

%% Results
    STATE -- output-time states --> POST
    FS -- spaces + measures --> POST
    POST -- derived fields + integrals --> IO
    STATE -- restart checkpoints --> IO
    IO -- files + metadata --> OUT
    ADV -- failures/timing/adaptivity --> OUT
    CACHE -- provenance hashes --> OUT
    IM -- mesh + tags --> OUT
