flowchart LR
    U([Config])
    CFG["Config parser + schema validation\nunits, dimensions, time, required sections"]
    SPEC["ProblemSpec IR\ncanonical, hashable, versioned"]
    UNITS["Units + coordinate frame\ncanonical scale"]
    TAGS["Semantic tag registry\nname, dim, id, role, coverage rules"]
    TIME["Time policy\nscheme, dt limits, output cadence, adaptivity"]
    CACHE["Artifact cache + provenance\nspec, CAD, mesh, form, operator hashes"]

    CQ["CadQuery geometry builder"]
    GEOCHK["Geometry validator\norientation, watertightness, scale, named entities"]
    GM["Gmsh mesher\nphysical groups + mesh size fields"]
    TAGMAP["Tag reconciliation\nsemantic tags ↔ gmsh physical groups"]
    MESHVAL["Mesh/topology validator\ncoverage, quality, MPI partition sanity"]
    IM["Mesh adapter\nGmsh → DOLFINx MeshData"]

    FS["Field/space registry\nscalar, vector, mixed blocks; measures"]
    DOFPLAN["DOF/block layout plan\nfield ordering, index sets, nullspace hints"]
    MDB["Material DB\nsemantic region → normalized params"]
    CF["Coefficient manager\nstatic + time-dependent fields"]
    MATLIB["Material law registry\nresponse + consistent tangent; state schema"]
    LOADS["Load/source manager\ntime-aware functions"]
    BCS["Constraint/BC manager\ntime-aware strong + weak terms"]
    IC["Initial/restart builder\nfields + internal variables"]
    TXNSTATE["Transactional state/history store\nu_n, history, trial internal vars, restart"]
    PRED["Predictor / extrapolator\ninitial guess for u_{n+1}"]

    PHYS["UFL nonlinear transient form factory\nresidual + Jacobian + optional P templates"]
    STEPCTX["Step context\nscheme, t, dt, history, coefficients"]
    FORMCHK["Form/tangent validation\narity, consistency, block shape, units"]
    FORMCOMPILE["Compiled-form cache\nresidual/Jacobian/preconditioner"]
    PROB["Nonlinear problem adapter\nF/J/P callbacks, BCs, nullspaces"]
    SNES["PETSc SNES solve\nline search/trust region + monitors"]
    ERR["Step convergence + physics checks\nresidual, estimator, invariants"]
    ADV["Advance controller\ncommit/reject, rollback, adapt dt"]

    OBS["Diagnostics/observability bus\nlogs, timings, PETSc reasons, provenance"]
    POST["Postprocess\nderived fields, probes, integrals"]
    IO["Output manager\nrestart checkpoints vs visualization cadence"]
    OUT["Outputs\ncheckpoints, time series, metadata, diagnostics"]

    U --> CFG --> SPEC
    SPEC --> UNITS
    SPEC --> TAGS
    SPEC -- time spec + adaptivity policy --> TIME
    SPEC --> CACHE
    SPEC -- geometry params --> CQ
    SPEC -- mesh params --> GM
    SPEC -- field/material/load/BC/physics/solver specs --> PHYS

    UNITS --> CQ
    CQ --> GEOCHK
    GEOCHK --> CACHE
    GEOCHK --> GM
    TAGS --> TAGMAP
    GM --> TAGMAP
    TAGMAP --> MESHVAL
    UNITS --> MESHVAL
    MESHVAL --> IM
    IM --> CACHE

    SPEC -- space spec --> FS
    IM --> FS
    TAGS --> FS
    FS --> DOFPLAN
    SPEC -- material map --> MDB
    UNITS --> MDB
    TAGS --> MDB
    MDB --> CF
    SPEC -- material law choices --> MATLIB
    CF --> MATLIB
    IM --> CF
    SPEC -- ic/restart spec --> IC
    FS -- spaces + quadrature/state spaces --> IC
    MATLIB -- initial internal variable schema --> IC
    IC -- initial fields + internal vars --> TXNSTATE
    SPEC --> LOADS
    SPEC --> BCS
    TIME -- t, dt --> CF
    TIME -- t, dt --> LOADS
    TIME -- t, dt --> BCS
    TAGS --> LOADS
    TAGS --> BCS
    IM --> LOADS
    IM --> BCS
    FS --> LOADS
    FS --> BCS

    TIME -- t, dt, step_id --> STEPCTX
    TXNSTATE -- committed history/internal vars --> PRED
    PRED -- u_guess --> SNES
    FS -- u, du, v, block spaces, measures --> PHYS
    MATLIB -- response + consistent tangent API --> PHYS
    TXNSTATE -- history + trial vars --> STEPCTX
    CF -- coefficients(t) --> STEPCTX
    LOADS -- terms(t) --> STEPCTX
    BCS -- weak terms(t) --> STEPCTX
    PHYS -- transient templates --> STEPCTX
    STEPCTX -- F_step, J_step, optional P_step --> FORMCHK
    FORMCHK --> FORMCOMPILE
    FORMCOMPILE --> PROB
    BCS -- strong constraints(t) --> PROB
    DOFPLAN -- nullspaces/index sets --> PROB
    PROB -- assemble callbacks --> SNES
    SPEC -- PETSc SNES/KSP/PC options --> SNES
    SNES -- trial iterate --> TXNSTATE
    TXNSTATE -- trial vars --> MATLIB
    SNES -- candidate u_{n+1} + solve_info --> ERR
    ERR -- accepted/rejected + suggested_dt --> ADV
    ADV -- commit accepted fields/internal vars --> TXNSTATE
    ADV -- rollback rejected step --> TXNSTATE
    ADV -- dt feedback --> TIME

    TXNSTATE -- output-time states --> POST
    FS --> POST
    POST --> IO
    TXNSTATE -- restart checkpoints --> IO
    SNES --> OBS
    ERR --> OBS
    ADV --> OBS
    CACHE --> OBS
    OBS --> OUT
    IO --> OUT
    IM --> OUT
