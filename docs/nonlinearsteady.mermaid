flowchart LR
    U([Config])
    CFG["Config parser + schema validation\nunits, dimensions, required sections"]
    SPEC["ProblemSpec IR\ncanonical, hashable, versioned"]
    UNITS["Units + coordinate frame\ncanonical scale"]
    TAGS["Semantic tag registry\nname, dim, id, role, coverage rules"]
    CACHE["Artifact cache + provenance\nspec, CAD, mesh, form, tangent hashes"]
    DAG["Execution DAG / artifact planner\nrecompute decisions, stage runners, invalidation"]
    CONTRACT["Geometry/mesh contract\ndimension, entity names, scale, tag coverage, cell type/order"]
    COUPLING["Multiphysics coupling manager\nmonolithic/staggered policy, block dependencies, transfer/projection"]
    RESTART["Restart schema/version manager\nmesh hash, space signature, fields, internal vars, provenance"]

    CQ["CadQuery geometry builder"]
    GEOCHK["Geometry validator\norientation, watertightness, scale, named entities"]
    GM["Gmsh mesher\nphysical groups + mesh size fields"]
    TAGMAP["Tag reconciliation\nsemantic tags ↔ gmsh physical groups"]
    MESHVAL["Mesh/topology validator\ncoverage, quality, MPI partition sanity"]
    IM["Mesh adapter\nGmsh → DOLFINx MeshData"]

    FS["Field/space registry\nscalar, vector, mixed blocks; measures"]
    DOFPLAN["DOF/block layout plan\nfield ordering, index sets, nullspace hints"]
    MDB["Material DB\nsemantic region → normalized params"]
    CF["Coefficient/constant builder\ncell-wise, facet-wise"]
    MATLIB["Material law registry\nenergy/residual/tangent; quadrature state schema"]
    TXNSTATE["Transactional state manager\ncommitted/trial internal vars; commit/rollback"]
    LOADS["Load/source builder\nsemantic facets/cells"]
    BCS["Constraint/BC registry\nstrong Dirichlet + weak/natural terms"]

    PHYS["UFL nonlinear form factory\nresidual + Jacobian + optional P"]
    FORMCHK["Form/tangent validation\narity, consistency, block shape, units"]
    FORMCOMPILE["Compiled-form cache\nresidual/Jacobian/preconditioner"]
    CONT["Continuation/load stepping\nload factor, u0, bounds, homotopy"]
    PROB["Nonlinear problem adapter\nF/J/P callbacks, BCs, nullspaces"]
    SNES["PETSc SNES solve\nline search/trust region + monitors"]
    CONV["Convergence gate\nresidual, update norm, physics checks"]

    OBS["Diagnostics/observability bus\nlogs, timings, PETSc reasons, provenance"]
    POST["Postprocess\nderived fields, probes, reactions"]
    IO["Output manager\nsolution, state, visualization"]
    OUT["Outputs\nsolution, state, metadata, diagnostics"]

    U --> CFG --> SPEC
    SPEC --> UNITS
    SPEC --> TAGS
    SPEC --> DAG --> CACHE
    SPEC -- geometry params --> CQ
    SPEC -- mesh params --> GM
    SPEC -- field/material/load/BC/physics/solver specs --> PHYS
    DAG -- geometry stage --> CQ
    DAG -- mesh stage --> GM
    DAG -- forms/solve stages --> PHYS
    DAG -- output stage --> IO
    CACHE -- reusable artifacts + provenance --> DAG

    UNITS --> CQ
    CQ --> GEOCHK
    GEOCHK --> CACHE
    GEOCHK -- geometry metadata --> CONTRACT
    GEOCHK --> GM
    TAGS --> TAGMAP
    TAGS -- required semantic coverage --> CONTRACT
    GM --> TAGMAP
    TAGMAP --> MESHVAL
    TAGMAP -- physical group ids/names --> CONTRACT
    UNITS --> MESHVAL
    CONTRACT -- mesh requirements --> MESHVAL
    MESHVAL --> IM
    CONTRACT -- import contract --> IM
    IM --> CACHE

    SPEC -- space spec --> FS
    IM --> FS
    TAGS --> FS
    FS --> DOFPLAN
    SPEC -- coupling policy --> COUPLING
    FS -- field blocks --> COUPLING
    DOFPLAN -- block dependencies/layout --> COUPLING
    SPEC -- material map --> MDB
    UNITS --> MDB
    TAGS --> MDB
    MDB --> CF
    IM --> CF
    CF --> MATLIB
    SPEC -- material law choices --> MATLIB
    FS -- quadrature/function spaces --> TXNSTATE
    MATLIB -- internal variable schema + initial values --> TXNSTATE
    SPEC --> LOADS
    SPEC --> BCS
    TAGS --> LOADS
    TAGS --> BCS
    IM --> LOADS
    IM --> BCS
    FS --> LOADS
    FS --> BCS

    SPEC -- continuation params + u0 --> CONT
    CONT -- current load factor + initial guess --> SNES
    FS -- u, du, v, block spaces, measures --> PHYS
    MATLIB -- response + consistent tangent API --> PHYS
    COUPLING -- coupled field plan --> PHYS
    TXNSTATE -- committed/trial vars --> PHYS
    LOADS -- body/natural terms --> PHYS
    BCS -- weak terms --> PHYS
    PHYS -- F, J, optional P --> FORMCHK
    FORMCHK --> FORMCOMPILE
    FORMCOMPILE --> PROB
    BCS -- strong constraints --> PROB
    DOFPLAN -- nullspaces/index sets --> PROB
    PROB -- assemble callbacks --> SNES
    SPEC -- PETSc SNES/KSP/PC options --> SNES
    SNES -- trial iterate --> TXNSTATE
    TXNSTATE -- trial vars --> MATLIB
    SNES -- candidate solution + solve_info --> CONV
    CONV -- accepted solution --> TXNSTATE
    CONV -- failed step / smaller increment --> CONT
    TXNSTATE -- commit accepted internal vars --> POST

    FS --> POST
    POST --> IO
    IM -- mesh hash + tag signature --> RESTART
    FS -- space signature --> RESTART
    TXNSTATE -- committed field/internal-var signatures --> RESTART
    CACHE -- provenance bundle --> RESTART
    RESTART -- compatible restart/checkpoint package --> IO
    IO --> OUT
    SNES --> OBS
    CONV --> OBS
    CACHE --> OBS
    OBS --> OUT
    IM --> OUT
