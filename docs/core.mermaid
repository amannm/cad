flowchart LR
    CFG["Config\nuser input, units, preferences"]
    VALIDCFG["Schema Validation\nPydantic models + JSON Schema\nstrict error locations"]
    UNITS["Unit System\nPint registry, canonical base units,\ndimensional metadata"]
    SPEC["ProblemSpec\ncanonical, normalized, hashable"]
    MODEL["DomainModel IR\ngeometry refs, fields, materials,\nloads, BCs, interfaces"]
    RUNPLAN["RunPlan\nmesh, solver, time, outputs,\ncheckpoint/restart policy"]

    CADAPI["CAD Kernel Adapter\ncompact internal API over CadQuery/OCC/Gmsh OCC"]
    GEOM["GeometryModel\nB-rep + stable semantic names"]
    TAGS["TagRegistry\nentity dim/id/name/material/interface\ncoverage + exclusivity policy"]
    MESHPLAN["MeshPlan\nsize fields, order, boundary layers,\ncurvature, adapt/refine policy"]
    MESH["SemanticMesh\nmesh + meshtags + CAD provenance"]
    MESHQA["MeshQualityGate\nvalidity, orientation, tag coverage,\nquality metrics, repair/adapt decisions"]

    FIELDS["FieldRegistry\nunknowns, spaces, components, units"]
    MAT["MaterialModel\nparameters, state variables, update law"]
    PHYS["PhysicsPackage\nUFL forms, IC/BC/load schema,\ninvariants, derived outputs"]
    COUPLE["CouplingGraph\nfield dependencies, block layout,\noperator ownership"]
    DISCRETE["DiscreteModel\nspaces, measures, dofs, BC/load bindings"]
    FORMCACHE["FormCompilerCache\nUFL/FFCx signatures, constants, kernels"]

    ASSEMBLY["AssemblyPlan / AlgebraicSystem\nF,J,P,A,b,M, nullspaces, BC application,\nMatNest/AIJ layout, reuse policy"]
    STATE["StateStore\ncurrent/trial/history/material state\ntransactions + commit/rollback"]
    STEPPER["Stepper\nsteady/transient/adaptive dt/load ramp/continuation"]
    PROFILE["SolverProfile\nPETSc prefix tree, KSP/SNES/PC,\nfieldsplit and fallback policy"]
    SOLVER["SolverDriver\none algebraic solve"]
    DIAG["Diagnostics\nresiduals, iterations, conservation checks,\nfallbacks, timings, option snapshot"]

    OUTPUTPLAN["OutputPlan\nfields, probes, cadence, format"]
    POST["Postprocess\nprobes, integrals, derived fields"]
    VIZ["VisualizationBundle\nmesh, fields, tags, time metadata"]
    INSITU["InSituHook optional\nParaView Catalyst adapter"]

    CKPTCTRL["CheckpointController\nADIOS2/HDF5 backend, cadence,\natomic write, retention"]
    CKPT["CheckpointPayload\nstate/history/time/material variables"]
    RESTART["RestartContract\nstrict compatibility manifest:\nspec/mesh/forms/versions/partitioning"]
    STORE["ArtifactStore\ncontent-addressed artifacts + provenance DAG"]
    REPORT["RunReport\nstatus, convergence, warnings, hashes"]
    VALID["Validation Gates\nschema, geometry, tags, mesh, physics,\nforms, solver, restart, outputs"]

    CFG --> VALIDCFG --> UNITS --> SPEC
    SPEC --> MODEL
    SPEC --> RUNPLAN
    MODEL --> CADAPI --> GEOM
    GEOM --> TAGS
    RUNPLAN --> MESHPLAN
    GEOM --> MESHPLAN --> MESH
    TAGS --> MESH
    MESH --> MESHQA
    MESHQA -->|accept| DISCRETE
    MESHQA -->|repair/adapt| MESHPLAN

    MODEL --> FIELDS
    MODEL --> MAT
    FIELDS --> PHYS
    MAT --> PHYS
    PHYS --> COUPLE
    FIELDS --> DISCRETE
    TAGS --> DISCRETE
    PHYS --> DISCRETE
    DISCRETE --> FORMCACHE --> ASSEMBLY
    COUPLE --> ASSEMBLY
    PHYS --> ASSEMBLY
    STATE --> ASSEMBLY

    RUNPLAN --> STEPPER
    STEPPER --> ASSEMBLY
    PROFILE --> SOLVER
    ASSEMBLY --> SOLVER
    SOLVER --> STATE
    SOLVER --> DIAG
    STEPPER --> DIAG
    ASSEMBLY --> DIAG

    RUNPLAN --> OUTPUTPLAN
    STATE --> POST
    PHYS --> POST
    OUTPUTPLAN --> POST --> VIZ
    POST --> INSITU

    STATE --> CKPTCTRL --> CKPT --> RESTART
    SPEC --> RESTART
    RUNPLAN --> RESTART
    MESH --> RESTART
    PHYS --> RESTART
    FORMCACHE --> RESTART

    SPEC --> STORE
    RUNPLAN --> STORE
    GEOM --> STORE
    TAGS --> STORE
    MESH --> STORE
    FORMCACHE --> STORE
    CKPT --> STORE
    VIZ --> STORE
    DIAG --> REPORT
    STORE --> REPORT
    RESTART --> REPORT

    VALID -.-> VALIDCFG
    VALID -.-> TAGS
    VALID -.-> MESHQA
    VALID -.-> DISCRETE
    VALID -.-> PHYS
    VALID -.-> ASSEMBLY
    VALID -.-> RESTART
